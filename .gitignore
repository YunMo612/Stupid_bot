# Python 缓存和虚拟环境
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# 敏感配置文件 (绝对不能提交！)
.env
.env.*
*.json  # 如果你的 json 存了用户数据，建议也不要提交，或者只提交一个 demo.json

# 日志与数据库
logs/
*.log
*.db
*.sqlite3

# 忽略真实的本地数据库文件
bot_data.json

# 忽略 WebUI 的自定义背景图
src/plugins/web_ui/frontend/background/bg.jpg
src/plugins/web_ui/frontend/background/bg.png

# 知识库 & MemPalace — 只保留目录结构，忽略数据文件
data/knowledge/docs/*
data/knowledge/chroma_db/
data/mempalace_db/
!data/knowledge/docs/.gitkeep
!data/knowledge/.gitkeep
!data/mempalace_db/.gitkeep
